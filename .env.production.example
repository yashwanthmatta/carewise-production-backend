CAREWISE_ENV=production
CAREWISE_SERVICE_NAME=carewise-api
CAREWISE_DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DATABASE
CAREWISE_REDIS_URL=
CAREWISE_JWT_SECRET=generate-with-scripts-generate-secrets
CAREWISE_FIELD_ENCRYPTION_KEY=generate-with-scripts-generate-secrets
CAREWISE_ACCESS_TOKEN_MINUTES=30
CAREWISE_REFRESH_TOKEN_DAYS=30
CAREWISE_ALLOWED_ORIGINS=https://your-frontend-domain.com
CAREWISE_OTEL_EXPORTER_OTLP_ENDPOINT=
CAREWISE_LOCAL_STORAGE_DIR=/tmp/carewise-storage
CAREWISE_STORAGE_BACKEND=local
CAREWISE_S3_BUCKET=
CAREWISE_S3_REGION=us-east-1
CAREWISE_S3_ENDPOINT_URL=
CAREWISE_OPENAI_API_KEY=
CAREWISE_OPENAI_OCR_MODEL=gpt-5.5
CAREWISE_STRIPE_SECRET_KEY=
CAREWISE_STRIPE_WEBHOOK_SECRET=
CAREWISE_STRIPE_SUCCESS_URL=https://your-frontend-domain.com/?checkout=success
CAREWISE_STRIPE_CANCEL_URL=https://your-frontend-domain.com/?checkout=cancelled
CAREWISE_PASSWORD_RESET_TOKEN_MINUTES=30
CAREWISE_FRONTEND_URL=https://your-frontend-domain.com
CAREWISE_SMTP_HOST=
CAREWISE_SMTP_PORT=587
CAREWISE_SMTP_USERNAME=
CAREWISE_SMTP_PASSWORD=
CAREWISE_SMTP_FROM_EMAIL=
CAREWISE_SMTP_USE_TLS=true
CAREWISE_AUTH_RATE_LIMIT_WINDOW_SECONDS=900
CAREWISE_AUTH_RATE_LIMIT_MAX_ATTEMPTS=8
CAREWISE_MAX_REPORT_FILE_BYTES=10485760
CAREWISE_ALLOWED_REPORT_CONTENT_TYPES=text/plain,application/pdf,image/png,image/jpeg,image/webp,image/heic
